PUBLIC_SITE_URL=https://www.tcfunesco.org
PUBLIC_SANITY_PROJECT_ID=8f53fq35
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2026-06-15
PUBLIC_SANITY_STUDIO_URL=https://tcfunesco.sanity.studio
SANITY_STUDIO_PROJECT_ID=8f53fq35
SANITY_STUDIO_DATASET=production
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Adobe Fonts — Layaan Arabic for hero Arabic tagline
# 1. https://fonts.adobe.com/fonts/layaan-arabic → Add to Web Project
# 2. Add domains: tcfunesco.org, www.tcfunesco.org, traditionalculturefoundation.pages.dev, localhost
# 3. Copy the Kit ID (7 chars, e.g. abc1xyz) from Project Settings
PUBLIC_ADOBE_FONTS_KIT_ID=
# Or paste the full stylesheet URL instead:
# PUBLIC_ADOBE_FONTS_CSS=https://use.typekit.net/xxxxx.css

# Trigger Cloudflare rebuild when Sanity content is published (optional)
SANITY_REVALIDATE_SECRET=replace_with_long_random_token
CLOUDFLARE_DEPLOY_HOOK_URL=

# Only needed for the optional demo seed script
SANITY_WRITE_TOKEN=replace_with_sanity_write_token_for_demo_seed_only

# Contact form (Phase 1 uses mailto, so these are OPTIONAL).
# Fill in ONE provider below and point ContactForm at /api/contact to enable
# server-side delivery instead of opening the visitor's email app.
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=office@tcfunesco.org
# CONTACT_FROM_EMAIL=website@tcfunesco.org
# FORMSPREE_ENDPOINT=
