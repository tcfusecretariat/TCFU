---
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsArticlePage from "@components/NewsArticlePage.astro";
import { content } from "@data/content";
import { getAllNews, getNewsBySlug } from "@lib/news";

export async function getStaticPaths() {
  const news = await getAllNews("en");
  return news.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const article = await getNewsBySlug("en", Astro.params.slug || "");
const t = content.en;
---

<BaseLayout locale="en" title={`${article?.seoTitle || article?.title || "Latest News"} | ${t.metaTitle}`} description={article?.seoDescription || article?.summary || t.metaDescription} path={`news/${Astro.params.slug}`}>
  <NewsArticlePage article={article} locale="en" slug={Astro.params.slug || ""} />
</BaseLayout>