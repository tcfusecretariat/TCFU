---
import BaseLayout from "@layouts/BaseLayout.astro";
import CmsListPage from "@components/CmsListPage.astro";
import { content } from "@data/content";

const locale = "en";
const t = content[locale];
---

<BaseLayout locale={locale} title={`Videos | ${t.metaTitle}`} description={t.metaDescription} path="videos">
  <CmsListPage locale={locale} kind="video" />
</BaseLayout>
