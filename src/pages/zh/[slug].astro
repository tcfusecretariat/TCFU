---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactPage from "@components/ContactPage.astro";
import PlaceholderPage from "@components/PlaceholderPage.astro";
import { content, staticPages } from "@data/content";

const locale = "zh";

export function getStaticPaths() {
  return staticPages.zh.map((page) => ({ params: { slug: page.slug }, props: page }));
}

const { title, slug } = Astro.props;
const t = content[locale];
---

<BaseLayout locale={locale} title={`${title} | ${t.metaTitle}`} description={t.metaDescription} path={slug}>
  {slug === "contact" ? <ContactPage locale={locale} title={title} /> : <PlaceholderPage title={title} locale={locale} />}
</BaseLayout>
