---
import BaseLayout from "@layouts/BaseLayout.astro";
import CmsListPage from "@components/CmsListPage.astro";
import { content } from "@data/content";

const locale = "zh";
const t = content[locale];
---

<BaseLayout locale={locale} title={`活動 | ${t.metaTitle}`} description={t.metaDescription} path="events">
  <CmsListPage locale={locale} kind="event" />
</BaseLayout>
