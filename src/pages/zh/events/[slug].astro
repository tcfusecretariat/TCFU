---
import BaseLayout from "@layouts/BaseLayout.astro";
import CmsDetailPage from "@components/CmsDetailPage.astro";
import { content } from "@data/content";
import { getItem, getItems } from "@lib/cms";

const locale = "zh";
export async function getStaticPaths() {
  const items = await getItems("event", "zh");
  return items.map((item) => ({ params: { slug: item.slug } }));
}

const item = await getItem("event", locale, Astro.params.slug || "");
const t = content[locale];
---

<BaseLayout locale={locale} title={`${item?.seoTitle || item?.title || "活動"} | ${t.metaTitle}`} description={item?.seoDescription || item?.description || t.metaDescription} path={`events/${Astro.params.slug || ""}`}>
  <CmsDetailPage locale={locale} kind="event" item={item} />
</BaseLayout>
