---
import BaseLayout from "@layouts/BaseLayout.astro";
import PrivacyPolicyPage from "@components/PrivacyPolicyPage.astro";
import { content } from "@data/content";
import { privacyPolicyContent } from "@data/privacy-policy-content";

const locale = "zh";
const site = content[locale];
const doc = privacyPolicyContent[locale];
---

<BaseLayout
  locale={locale}
  title={`${doc.title} | ${site.metaTitle}`}
  description="聯合國教科文組織傳統文化基金會隱私政策——我們如何收集、使用及保護個人資料。"
  path="privacy-policy"
>
  <PrivacyPolicyPage locale={locale} />
</BaseLayout>
