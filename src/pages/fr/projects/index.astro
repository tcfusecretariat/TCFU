---
import BaseLayout from "@layouts/BaseLayout.astro";
import CmsListPage from "@components/CmsListPage.astro";
import { content } from "@data/content";

const locale = "fr";
const t = content[locale];
---

<BaseLayout locale={locale} title={`Projets | ${t.metaTitle}`} description={t.metaDescription} path="projects">
  <CmsListPage locale={locale} kind="project" />
</BaseLayout>
