---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactPage from "@components/ContactPage.astro";
import PlaceholderPage from "@components/PlaceholderPage.astro";
import { content, projects, staticPages } from "@data/content";

const locale = "fr";

export function getStaticPaths() {
  const pages = staticPages.fr.map((page) => ({ params: { slug: page.slug }, props: page }));
  const projectPages = projects.map((project) => ({
    params: { slug: project.href },
    props: { slug: project.href, title: project.fr, message: "Cette page est en cours de construction. Revenez bientôt." }
  }));
  return [...pages, ...projectPages];
}

const { title, slug, message } = Astro.props as { title: string; slug: string; message?: string };
const t = content[locale];
---

<BaseLayout locale={locale} title={`${title} | ${t.metaTitle}`} description={t.metaDescription} path={slug}>
  {slug === "contact" ? <ContactPage locale={locale} title={title} /> : <PlaceholderPage title={title} locale={locale} message={message} />}
</BaseLayout>
