---
import BaseLayout from "@layouts/BaseLayout.astro";
import ResourceLibraryPage from "@components/ResourceLibraryPage.astro";
import { content } from "@data/content";

const locale = "fr";
const t = content[locale];
---

<BaseLayout locale={locale} title={`Ressources | ${t.metaTitle}`} description={t.metaDescription} path="library">
  <ResourceLibraryPage locale={locale} />
</BaseLayout>
