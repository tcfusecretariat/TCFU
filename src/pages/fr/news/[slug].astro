---
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsArticlePage from "@components/NewsArticlePage.astro";
import { content } from "@data/content";
import { getAllNews, getNewsBySlug } from "@lib/news";

export async function getStaticPaths() {
  const news = await getAllNews("fr");
  return news.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const article = await getNewsBySlug("fr", Astro.params.slug || "");
const t = content.fr;
---

<BaseLayout locale="fr" title={`${article?.seoTitle || article?.title || "Actualités"} | ${t.metaTitle}`} description={article?.seoDescription || article?.summary || t.metaDescription} path={`news/${Astro.params.slug}`}>
  <NewsArticlePage article={article} locale="fr" slug={Astro.params.slug || ""} />
</BaseLayout>