---
import "@styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CookieBanner from "@components/CookieBanner.astro";
import ContactDialog from "@components/ContactDialog.astro";
import { languages, siteSettings, defaultLocale, type Locale } from "@data/site";
import { hreflangLinks } from "@lib/seo";

type Props = {
  locale: Locale;
  title: string;
  description: string;
  path?: string;
  image?: string;
};

const { locale, title, description, path = "", image = siteSettings.defaultOgImage } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://traditionalculturefoundation.org";
const canonical = new URL(`/${locale}/${path}`.replace(/\/{2,}/g, "/"), `${siteUrl}/`).toString();
const ogImage = new URL(image, `${siteUrl}/`).toString();
const alternateLinks = hreflangLinks(path).map((link) => ({
  lang: link.lang,
  href: new URL(link.href, `${siteUrl}/`).toString()
}));
const xDefaultHref = new URL(`/${defaultLocale}/${path}`.replace(/\/{2,}/g, "/"), `${siteUrl}/`).toString();
const cloudflareAnalyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN;
const adobeFontsKit = import.meta.env.PUBLIC_ADOBE_FONTS_KIT_ID;
const adobeFontsCss =
  import.meta.env.PUBLIC_ADOBE_FONTS_CSS ||
  (adobeFontsKit ? `https://use.typekit.net/${adobeFontsKit}.css` : "https://use.typekit.net/utx6cie.css");
const cloudflareBeacon = JSON.stringify({ token: cloudflareAnalyticsToken });
const analyticsScript = cloudflareAnalyticsToken
  ? `<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='${cloudflareBeacon}'></script>`
  : "";
---

<!doctype html>
<html lang={languages[locale].lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((link) => <link rel="alternate" hreflang={link.lang} href={link.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {adobeFontsCss && (
      <>
        <link rel="preconnect" href="https://use.typekit.net" crossorigin />
        <link rel="preconnect" href="https://p.typekit.net" crossorigin />
        <link rel="stylesheet" href={adobeFontsCss} />
      </>
    )}
    {locale === "zh" && (
      <link
        rel="preload"
        href="/assets/fonts/cwTeXKai-zhonly.woff2"
        as="font"
        type="font/woff2"
        crossorigin
      />
    )}
    <Fragment set:html={analyticsScript} />
  </head>
  <body>
    <Header locale={locale} />
    <slot />
    <Footer locale={locale} />
    <ContactDialog locale={locale} />
    <CookieBanner locale={locale} />
    <script is:inline>
      document.querySelectorAll(".contact-trigger").forEach((trigger) => {
        trigger.addEventListener("click", () => document.querySelector("dialog.contact-dialog")?.showModal());
      });

      document.querySelectorAll("dialog.contact-dialog").forEach((dialog) => {
        dialog.addEventListener("click", (event) => {
          if (event.target === dialog) dialog.close();
        });
      });

      document.querySelectorAll(".dialog-close").forEach((button) => {
        button.addEventListener("click", () => button.closest("dialog")?.close());
      });

      document.querySelectorAll("form.contact-form").forEach((form) => {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          const status = form.querySelector("[data-form-status]");
          const submitButton = form.querySelector('button[type="submit"]');
          const success = form.dataset.success || "Message sent.";
          const error = form.dataset.error || "Unable to send your message.";
          const sending = form.dataset.sending || "Sending…";
          const endpoint = form.dataset.endpoint || "/api/contact";

          if (status) {
            status.textContent = sending;
            status.dataset.state = "";
          }
          if (submitButton) submitButton.disabled = true;

          const formData = new FormData(form);
          const name = String(formData.get("name") || "").trim();
          const fromEmail = String(formData.get("email") || "").trim();
          const message = String(formData.get("message") || "").trim();
          const consent = formData.get("gdpr-consent");

          if (!name || !fromEmail || !message || !consent) {
            if (status) {
              status.textContent = error;
              status.dataset.state = "error";
            }
            if (submitButton) submitButton.disabled = false;
            return;
          }

          try {
            const response = await fetch(endpoint, {
              method: "POST",
              body: formData,
              headers: { Accept: "application/json" }
            });
            const result = await response.json().catch(() => ({}));

            if (!response.ok || !result.ok) {
              throw new Error(result.message || error);
            }

            if (status) {
              status.textContent = result.message || success;
              status.dataset.state = "success";
            }
            form.reset();
          } catch (submitError) {
            if (status) {
              status.textContent = submitError instanceof Error ? submitError.message : error;
              status.dataset.state = "error";
            }
          } finally {
            if (submitButton) submitButton.disabled = false;
          }
        });
      });

      document.querySelectorAll(".nav-toggle").forEach((button) => {
        button.addEventListener("click", () => {
          const menu = document.getElementById(button.getAttribute("aria-controls") || "");
          const expanded = button.getAttribute("aria-expanded") === "true";
          button.setAttribute("aria-expanded", String(!expanded));
          menu?.toggleAttribute("data-open", !expanded);
        });
      });

      const lightbox = document.createElement("dialog");
      lightbox.className = "lightbox-dialog";
      lightbox.innerHTML = '<button type="button" class="dialog-close" aria-label="Close">×</button><img alt="" /><p></p>';
      document.body.append(lightbox);
      lightbox.querySelector("button")?.addEventListener("click", () => lightbox.close());
      document.querySelectorAll("[data-lightbox] img, img[data-lightbox]").forEach((image) => {
        image.addEventListener("click", () => {
          const img = lightbox.querySelector("img");
          const caption = lightbox.querySelector("p");
          img.src = image.currentSrc || image.src;
          img.alt = image.alt || "";
          caption.textContent = image.alt || "";
          lightbox.showModal();
        });
      });
    </script>
  </body>
</html>
