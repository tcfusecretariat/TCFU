---
import { content } from "@data/content";
import type { Locale } from "@data/site";
import { getSiteSettings } from "@lib/cms";

const { locale, class: className = "", dialogMode = false } = Astro.props as {
  locale: Locale;
  class?: string;
  dialogMode?: boolean;
};
const t = content[locale].contact;
const settings = await getSiteSettings();
const intro = t.intro.replace("office@tcfunesco.org", settings.email);
---

<form
  class:list={["contact-form", className]}
  action={`mailto:${settings.email}`}
  method="post"
  data-email={settings.email}
  data-success={t.success}
  data-error={t.error}
  data-sending={t.sending}
>
  {dialogMode && <button class="dialog-close" type="button" aria-label="Close">×</button>}
  <input type="hidden" name="locale" value={locale} />
  <p class="section-kicker">{t.title}</p>
  <h2 id={dialogMode ? "contact-dialog-title" : undefined}>{t.title}</h2>
  <p>{intro}</p>
  <label><span>{t.name}</span><input name="name" type="text" required autocomplete="name" /></label>
  <label><span>{t.email}</span><input name="email" type="email" required autocomplete="email" /></label>
  <label><span>{t.subject}</span><input name="subject" type="text" autocomplete="off" /></label>
  <label><span>{t.message}</span><textarea name="message" rows="6" required></textarea></label>
  <label class="consent-field">
    <input name="gdpr-consent" type="checkbox" required />
    <span>
      {locale === "zh" ? (
        <>
          我同意基金會依<a href={`/${locale}/privacy-policy/`}>隱私政策</a>使用此表單資料，以回覆我的詢問。
        </>
      ) : locale === "fr" ? (
        <>
          J’accepte que la Fondation utilise les données de ce formulaire pour répondre à ma demande conformément à
          la <a href={`/${locale}/privacy-policy/`}>politique de confidentialité</a>.
        </>
      ) : (
        <>
          I agree that the Foundation may use this form data to respond to my inquiry according to the{" "}
          <a href={`/${locale}/privacy-policy/`}>Privacy Policy</a>.
        </>
      )}
    </span>
  </label>
  <button class="button primary" type="submit">{t.submit}</button>
  <p class="form-status" data-form-status aria-live="polite"></p>
</form>
