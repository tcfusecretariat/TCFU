---
import { getLogoStory } from "@data/logo-story";
import type { Locale } from "@data/site";

const { locale } = Astro.props as { locale: Locale };
const story = getLogoStory(locale);
---

<section class="logo-story-section editorial-reveal" aria-labelledby="logo-story-heading">
  <div class="logo-story-intro">
    <h2 id="logo-story-heading">{story.sectionTitle}</h2>
    <p class="logo-story-lead">{story.sectionSubtitle}</p>
  </div>

  <div class="logo-story-categories">
    {
      story.steps.map((step) => (
        <article class="logo-story-category" id={`logo-story-${step.id}`}>
          <h3>{step.title}</h3>
          <p class="logo-story-step-subtitle">{step.subtitle}</p>
          <p>{step.text}</p>
        </article>
      ))
    }
  </div>
</section>
