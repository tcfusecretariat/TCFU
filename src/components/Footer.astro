---
import { content } from "@data/content";
import type { Locale } from "@data/site";
import { getSiteSettings } from "@lib/cms";

const { locale } = Astro.props as { locale: Locale };
const t = content[locale];
const settings = await getSiteSettings(locale);
const helloAssoUrl = settings.helloAssoUrl;
const logoAlt =
  locale === "zh"
    ? "聯合國教科文組織傳統文化基金會"
    : "Traditional Culture Foundation at UNESCO";
---

<footer class="site-footer">
  <div class="footer-brand">
    <img src={settings.logo} alt={logoAlt} />
  </div>
  {settings.footer && <p class="footer-note">{settings.footer}</p>}
  <div class="footer-links">
    <button class="footer-link contact-trigger" type="button">{t.footer.contact}</button>
    <a href={helloAssoUrl} target="_blank" rel="noopener">{t.footer.donate}</a>
    <a href={`/${locale}/privacy-policy/`}>{t.footer.privacy}</a>
  </div>
  <div class="footer-social" aria-label="Social media">
    {settings.socialLinks.map((link) => (
      <a href={link.url} target="_blank" rel="noopener" aria-label={link.label}>
        {link.label.toLowerCase().includes("youtube") ? (
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21.58 7.19a2.77 2.77 0 0 0-1.95-1.95C17.91 4.78 12 4.78 12 4.78s-5.91 0-7.63.46a2.77 2.77 0 0 0-1.95 1.95A28.8 28.8 0 0 0 2 12a28.8 28.8 0 0 0 .42 4.81 2.77 2.77 0 0 0 1.95 1.95c1.72.46 7.63.46 7.63.46s5.91 0 7.63-.46a2.77 2.77 0 0 0 1.95-1.95A28.8 28.8 0 0 0 22 12a28.8 28.8 0 0 0-.42-4.81ZM10 15.28V8.72L15.68 12 10 15.28Z" /></svg>
        ) : link.label.toLowerCase().includes("instagram") ? (
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8Zm8.7 2.4a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7.15A4.85 4.85 0 1 1 12 16.85 4.85 4.85 0 0 1 12 7.15Zm0 2A2.85 2.85 0 1 0 12 14.85 2.85 2.85 0 0 0 12 9.15Z" /></svg>
        ) : (
          <span>{link.label.slice(0, 1)}</span>
        )}
      </a>
    ))}
  </div>
</footer>
