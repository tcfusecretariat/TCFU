---
import PlaceholderPage from "@components/PlaceholderPage.astro";
import PortableBody from "@components/PortableBody.astro";
import SanityLiveNews from "@components/SanityLiveNews.astro";
import type { Locale } from "@data/site";
import type { NewsDetail } from "@lib/news";

const { article, locale, slug } = Astro.props as {
  article: NewsDetail | null;
  locale: Locale;
  slug: string;
};
---

{article ? (
  <main class="idea-section editorial-reveal" data-sanity-news-article>
    <p class="section-kicker">{article.category || "News"}</p>
    <div class="idea-layout">
      <h1>{article.title}</h1>
      <div>
        {article.publishDate && <p><time datetime={article.publishDate}>{new Date(article.publishDate).toLocaleDateString()}</time></p>}
        {article.summary && <p>{article.summary}</p>}
        {article.body && <PortableBody value={article.body} />}
        {article.videoUrl && <p><a class="text-link" href={article.videoUrl}>Video</a></p>}
        {article.pdfUrl && <p><a class="text-link" href={article.pdfUrl}>PDF</a></p>}
      </div>
    </div>
  </main>
) : (
  <div data-sanity-news-article>
    <PlaceholderPage title="News" locale={locale} />
  </div>
)}
<SanityLiveNews locale={locale} mode="article" slug={slug} />
