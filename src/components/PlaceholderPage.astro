---
import { placeholderText } from "@data/content";
import { defaultLocale, type Locale } from "@data/site";

const { title, kicker = title, locale = defaultLocale, message } = Astro.props as {
  title: string;
  kicker?: string;
  locale?: Locale;
  message?: string;
};
const resolvedMessage = message || placeholderText[locale] || placeholderText.en;
---

<main class="placeholder-page">
  <section class="placeholder-content editorial-reveal">
    <p class="section-kicker">{kicker}</p>
    <h1>{title}</h1>
    <p>{resolvedMessage}</p>
  </section>
</main>
